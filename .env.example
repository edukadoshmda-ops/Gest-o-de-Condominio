# ============================================================
# ATENÇÃO: Este arquivo NÃO é SQL. NÃO cole no SQL Editor do Supabase.
# É só configuração para o projeto. Use no seu PC como arquivo .env
# Para o SQL Editor, use os arquivos da pasta supabase/*.sql
# ============================================================
# Supabase - copie para .env e preencha com suas credenciais
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Só para scripts no PC (NUNCA use no front-end): criar usuário super admin
# Dashboard > Settings > API > service_role (secret)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Superadmin: use este e-mail para entrar como administrador master (opcional)
# VITE_SUPERADMIN_EMAIL=seu@email.com

# Web Push (opcional): chave pública VAPID para notificações no dispositivo
# Gerar novas chaves: npm run vapid  (veja docs/NOTIFICACOES.md)
